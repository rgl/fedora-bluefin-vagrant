Vagrant.configure(2) do |config|
  config.vm.box = 'fedora-bluefin-44-amd64'

  config.vm.provider 'libvirt' do |lv, config|
    lv.memory = 4 * 1024
    lv.cpus = 4
    lv.cpu_mode = 'host-passthrough'
    lv.nested = true
    lv.keymap = 'pt'
    lv.disk_driver :discard => 'unmap', :cache => 'unsafe'
    # NB in Fedora Bluefin, / is read-only, so use /var instead.
    config.vm.synced_folder '.', '/vagrant', disabled: true
    config.vm.synced_folder '.', '/var/vagrant', type: 'nfs', nfs_version: '4.2', nfs_udp: false
  end

  # configure the desktop.
  # NB these settings were obtained as follows:
  #       1. dconf dump / >dconf.orig.ini
  #       2. edit the appearance settings using the GUI
  #       3. dconf dump / >dconf.ini
  #       4. diff -u dconf.orig.ini dconf.ini
  # See /usr/share/glib-2.0/schemas/org.gnome.desktop.interface.gschema.xml
  config.vm.provision 'shell', name: 'Set dark theme', privileged: false, inline: "dbus-launch dconf write /org/gnome/desktop/interface/color-scheme \"'prefer-dark'\""

  # enable remote desktop.
  # NB you can connect to the VM using RDP:
  #     xfreerdp /v:192.168.121.23:3389 /u:rdp /p:vagrant /dynamic-resolution /scale-desktop:200
  config.vm.provision 'shell', name: 'Enable remote desktop', inline: <<-EOF
    set -eux
    grdctl --system rdp set-credentials rdp vagrant
    sudo -u gnome-remote-desktop \
      openssl req -new -newkey rsa:4096 -days 365 -nodes -x509 -subj /CN=rdp \
      -out ~gnome-remote-desktop/.local/share/gnome-remote-desktop/tls.crt \
      -keyout ~gnome-remote-desktop/.local/share/gnome-remote-desktop/tls.key
    grdctl --system rdp set-tls-key ~gnome-remote-desktop/.local/share/gnome-remote-desktop/tls.key
    grdctl --system rdp set-tls-cert ~gnome-remote-desktop/.local/share/gnome-remote-desktop/tls.crt
    grdctl --system rdp enable
    systemctl daemon-reload
    systemctl enable gnome-remote-desktop
    systemctl restart gnome-remote-desktop
    systemctl status gnome-remote-desktop
    grdctl --system status --show-credentials
    ip addr show eth0
    EOF

  # show system information.
  config.vm.provision 'shell', name: 'Show system information', inline: <<-EOF
    set -eux
    cat /etc/os-release
    uname -a
    echo "machine-id is $(cat /etc/machine-id)"
    lsblk -o KNAME,SIZE,TRAN,FSTYPE,UUID,LABEL,MODEL,SERIAL
    sfdisk -l /dev/sda
    df -h
    lsblk
    findmnt /
    findmnt /etc
    findmnt /var
    findmnt /sysroot
    mount | grep /dev/sda | sort
    btrfs filesystem show
    btrfs filesystem df -h /sysroot
    btrfs subvolume list -t /sysroot
    bootc --version
    bootc status #--format yaml
    EOF
end
